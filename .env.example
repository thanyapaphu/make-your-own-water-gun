# Copy to .env (not committed). Then (Node 20+): npm run build:local
# Or: export SUPABASE_URL=... SUPABASE_ANON_KEY=... && npm run build
#
# Vercel: Project → Settings → Environment Variables (turn on Production + Preview).
# After adding or changing vars, redeploy — build reads env only during the build step.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
